# ════════════════════════════════════════════════════════════
#  NL2SQL Chatbot — Environment Configuration
#  Copy this file to .env and fill in your values.
# ════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────
# SQLite (default fallback):
#   DATABASE_URL=sqlite:///./default.db
# PostgreSQL:
#   DATABASE_URL=postgresql+psycopg2://user:password@host:port/dbname
# SQL Server (MSSQL):
#   DATABASE_URL=mssql+pyodbc://user:pass@host,port/db?driver=ODBC+Driver+17+for+SQL+Server&Encrypt=no&TrustServerCertificate=yes
DATABASE_URL=sqlite:///./default.db
FERNET_KEY=PASTE_GENERATED_KEY_HERE
# ── LLM (OpenAI or compatible) ───────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b


# ── Query safety ─────────────────────────────────────────────
DEFAULT_ROW_LIMIT=500      # auto-injected LIMIT/TOP for non-aggregate queries
MAX_ROW_LIMIT=1000         # absolute ceiling (safety net)

# ── Application ───────────────────────────────────────────────
APP_NAME=NL2SQL Chatbot
DEBUG=false
CORS_ORIGINS=["*"]

# ── Connection pool ───────────────────────────────────────────

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
