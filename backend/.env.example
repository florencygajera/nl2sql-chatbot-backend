# ════════════════════════════════════════════════════════════
#  NL2SQL Chatbot — Environment Configuration
#  Copy this file to .env and fill in your values.
# ════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────
# SQLite: sqlite:///./db.sqlite
# PostgreSQL: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=sqlite:///./default.db

# ── Query safety ─────────────────────────────────────────────
DEFAULT_ROW_LIMIT=50      # auto-injected LIMIT for non-aggregate queries
MAX_ROW_LIMIT=500         # absolute ceiling (safety net)

# ── Application ───────────────────────────────────────────────
APP_NAME=NL2SQL Chatbot
DEBUG=false
CORS_ORIGINS=["*"]

# ── Connection pool ───────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Performance / Caching ─────────────────────────────────────
# Enable schema caching (reduces DB introspection calls)
ENABLE_SCHEMA_CACHE=true
SCHEMA_CACHE_TTL_SECONDS=300

# Enable LLM response caching (reduces repeated identical queries)
ENABLE_LLM_CACHE=true
LLM_CACHE_TTL_SECONDS=600
ENABLE_SCHEMA_EMBEDDINGS=false

# LLM connection pool settings (reduces TCP handshake overhead)
LLM_MAX_CONNECTIONS=10
LLM_TIMEOUT_SECONDS=120

# Enable request performance monitoring
ENABLE_PERFORMANCE_MONITORING=true
